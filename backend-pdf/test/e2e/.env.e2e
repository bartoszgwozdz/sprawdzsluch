# Konfiguracja backend-pdf na czas testów e2e.
# Wskazuje na lokalną infrastrukturę z docker-compose.yml.
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# MongoDB z docker-compose (port 27018 -> 27017 w kontenerze)
MONGODB_URI=mongodb://localhost:27018/sprawdzsluch

# SMTP -> Mailpit (bez uwierzytelniania)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@sprawdzsluch.pl
